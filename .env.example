# Copy this file to ".env" and fill in your values. ".env" is gitignored.
#
# Supabase: Project Settings -> Database -> Connection string -> URI (Session/Pooler).
# Leave DATABASE_URL empty to use the bundled maps.json (file fallback, zero-config).
DATABASE_URL=

# Seconds between automatic map reloads from the backend (admin edits propagate
# without restarting the server). Set to 0 to disable.
MAP_RELOAD_SECONDS=30
